    "@capacitor/status-bar": "^8.0.2",
    "@iconify/json": "^2.2.471",
    "@iconify/react": "^6.0.2",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@supabase/supabase-js": "^2.106.2",
    "@upstash/qstash": "^2.11.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/postgres": "^0.10.0",
    "ai": "^6.0.170",
    "canvas-confetti": "^1.9.4",
    "cheerio": "^1.2.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "ioredis": "^5.11.0",
    "lucide-react": "^0.462.0",
    "next": "^16.2.6",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.0.227",
    "pg": "^8.21.0",
    "phaser": "^4.2.0",
    "phosphor-react": "^1.4.1",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.19.42",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
