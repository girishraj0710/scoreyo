{
  "name": "krakkify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "mobile:sync": "npx cap sync",
    "mobile:ios": "npx cap open ios",
    "mobile:android": "npx cap open android",
    "mobile:run:ios": "npx cap run ios",
    "mobile:run:android": "npx cap run android",
    "mobile:build:ios": "npx cap build ios",
    "mobile:build:android": "npx cap build android",
    "scrape": "tsx scripts/scrape-ncert.ts",
    "test-scraper": "tsx scripts/test-scraper.ts",
    "process-local-pdfs": "tsx scripts/process-local-pdfs.ts",
    "scrape-nta": "tsx scripts/scrape-nta-papers.ts",
    "scrape-openstax": "tsx scripts/scrape-openstax.ts",
    "download-openstax": "tsx scripts/download-openstax.ts",
    "analyze-topics": "tsx scripts/analyze-topics.ts",
    "scrape-topics": "tsx scripts/targeted-topic-scraper.ts",
    "scrape-topics-free": "tsx scripts/free-topic-scraper.ts",
    "seed:questions": "tsx scripts/seed-questions-ollama.ts",
    "seed:setup": "tsx scripts/setup-ollama.ts",
    "fill:gaps": "tsx scripts/fill-question-gaps-ollama.ts",
    "generate-questions": "tsx scripts/generate-via-api.ts",
    "scale:setup": "chmod +x scripts/setup-redis.sh && ./scripts/setup-redis.sh",
    "scale:test": "npm run dev",
    "scale:deploy": "vercel --prod",
    "scale:check": "echo '✅ Checking scaling setup...' && npm run scale:check-redis && npm run scale:check-db",
    "scale:check-redis": "node -e \"const {Redis}=require('@upstash/redis');const r=new Redis({url:process.env.UPSTASH_REDIS_REST_URL,token:process.env.UPSTASH_REDIS_REST_TOKEN});r.ping().then(()=>console.log('✅ Redis: Connected')).catch(()=>console.log('❌ Redis: Failed'))\"",
    "scale:check-db": "node -e \"const {Pool}=require('pg');const p=new Pool({connectionString:process.env.POSTGRES_URL});p.query('SELECT 1').then(()=>{console.log('✅ PostgreSQL: Connected');p.end()}).catch(e=>{console.log('❌ PostgreSQL: Failed',e.message);p.end()})\""
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
