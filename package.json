    "scale:deploy": "vercel --prod",
    "scale:check": "echo '✅ Checking scaling setup...' && npm run scale:check-redis && npm run scale:check-db",
    "scale:check-redis": "node -e \"const {Redis}=require('@upstash/redis');const r=new Redis({url:process.env.UPSTASH_REDIS_REST_URL,token:process.env.UPSTASH_REDIS_REST_TOKEN});r.ping().then(()=>console.log('✅ Redis: Connected')).catch(()=>console.log('❌ Redis: Failed'))\"",
    "scale:check-db": "turso db show prepgenie-girishraj0710 || echo '⚠️  Turso CLI not installed'"
